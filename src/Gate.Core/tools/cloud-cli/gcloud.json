{
  "toolName": "gcloud",
  "displayName": "Google Cloud CLI",
  "category": "云 CLI",
  "executable": "gcloud",
  "envProxy": {
    "httpVars":    ["HTTPS_PROXY", "HTTP_PROXY",  "http_proxy"],
    "httpsVars":   ["HTTPS_PROXY", "https_proxy"],
    "noProxyVars": ["NO_PROXY",    "no_proxy"],
    "scope": "user"
  },
  "notes": "gcloud 优先读取 HTTPS_PROXY，因为大多数请求走 HTTPS"
}
