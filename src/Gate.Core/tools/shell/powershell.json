{
  "toolName": "powershell",
  "displayName": "PowerShell",
  "category": "Shell",
  "executable": {
    "windows": "pwsh.exe",
    "linux":   "pwsh",
    "macos":   "pwsh"
  },
  "envProxy": {
    "httpVars":    ["HTTP_PROXY",  "http_proxy"],
    "httpsVars":   ["HTTPS_PROXY", "https_proxy"],
    "noProxyVars": ["NO_PROXY",    "no_proxy"],
    "scope": "user"
  }
}
