{
  "toolName": "swift-pm",
  "displayName": "Swift Package Manager",
  "category": "移动开发",
  "executable": "swift",
  "envProxy": {
    "httpVars":    ["HTTP_PROXY",  "http_proxy"],
    "httpsVars":   ["HTTPS_PROXY", "https_proxy"],
    "noProxyVars": ["NO_PROXY",    "no_proxy"],
    "scope": "process"
  }
}
