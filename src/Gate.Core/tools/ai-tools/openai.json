{
  "toolName": "openai",
  "displayName": "OpenAI SDK / CLI",
  "category": "AI 工具",
  "executable": "openai",
  "envProxy": {
    "httpVars":    ["OPENAI_PROXY",  "HTTP_PROXY",  "http_proxy"],
    "httpsVars":   ["OPENAI_PROXY",  "HTTPS_PROXY", "https_proxy"],
    "noProxyVars": ["NO_PROXY",      "no_proxy"],
    "scope": "user"
  }
}
